{
    "name": "wackowiki/diff",
    "description": "PHP diff library modernized for PHP 8.5",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "François Pinard",
            "email": "pinard@iro.umontreal.ca",
            "role": "Original author"
        },
        {
            "name": "Geoffrey T. Dairiki",
            "email": "dairiki@dairiki.org",
            "role": "Original author"
        },
        {
            "name": "David DELON",
            "role": "Contributor"
        },
        {
            "name": "Patrick PAUL",
            "role": "Contributor"
        },
        {
            "name": "Eric FELDSTEIN",
            "role": "Contributor"
        }
    ],
    "support": {
        "issues": "https://github.com/wackowiki/diff/issues",
        "source": "https://github.com/wackowiki/diff"
    },
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Diff\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Diff\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "test:verbose": "phpunit --testdox",
        "test:coverage": "phpunit --coverage-text",
        "test:filter": "phpunit --filter"
    }
}

